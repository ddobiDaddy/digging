# --- 추천 엔진 선택 ---
# false (기본): 룰 기반 엔진 사용. Ollama 불필요.
# true       : Ollama AI 사용 (사전에 'ollama serve' + 모델 pull 필요)
USE_AI=false

# --- Ollama (USE_AI=true 일 때만 사용) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# --- 공유 링크 (카톡/OG 메타) ---
# 배포 도메인. 로컬은 기본 http://localhost:3000
SITE_URL=http://localhost:3000

# --- Naver 검색 API (장소 추천에 사용) ---
# https://developers.naver.com/ 에서 발급. README의 "1. 네이버 검색 API 키 발급" 참고.
# 비워두면 추천 카테고리만 보이고 실제 장소 카드는 표시되지 않습니다.
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
